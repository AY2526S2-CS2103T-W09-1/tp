@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":CopyCommandParser" as CopyCommandParser LOGIC_COLOR
participant "c:CopyCommand" as CopyCommand LOGIC_COLOR
participant "result:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box

box OS UI_COLOR_T1
participant "<<class>>\nClipboard" as Clipboard UI_COLOR
end box

[-> LogicManager : execute("copy 1")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("copy 1")
activate AddressBookParser

create CopyCommandParser
AddressBookParser -> CopyCommandParser
activate CopyCommandParser
CopyCommandParser --> AddressBookParser
deactivate CopyCommandParser

AddressBookParser -> CopyCommandParser : parse("1")
activate CopyCommandParser

create CopyCommand
CopyCommandParser -> CopyCommand : CopyCommand(1, null)
activate CopyCommand
CopyCommand --> CopyCommandParser : c
deactivate CopyCommand

CopyCommandParser --> AddressBookParser : c
deactivate CopyCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
CopyCommandParser -[hidden]-> AddressBookParser
destroy CopyCommandParser

AddressBookParser --> LogicManager : c
deactivate AddressBookParser

LogicManager -> CopyCommand : execute(model)
activate CopyCommand

CopyCommand -> Model : getFilteredPersonList()
activate Model
Model --> CopyCommand : lastShownList
deactivate Model

CopyCommand -> Clipboard : getSystemClipboard()
activate Clipboard
Clipboard --> CopyCommand : clipboard
deactivate Clipboard

CopyCommand -> Clipboard : setContent(generatedString)
activate Clipboard
Clipboard --> CopyCommand
deactivate Clipboard

create CommandResult
CopyCommand -> CommandResult
activate CommandResult
CommandResult --> CopyCommand : result
deactivate CommandResult

CopyCommand --> LogicManager : result
deactivate CopyCommand

[<--LogicManager
deactivate LogicManager
@enduml